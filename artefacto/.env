# Servidor de producción
SERVER_URL=http://54.37.226.179/api/collect

# Modo debug (0 = desactivado, 1 = activado)
DEBUG=0

# Timeout para peticiones HTTP (aumentado para payloads grandes con screenshots)
TIMEOUT=120s

# ========== XSS AUDIT MODE ==========
# Activa el modo de auditoría XSS para detectar vulnerabilidades en sandboxes
# ADVERTENCIA: Solo usar con fines de investigación de seguridad y con permiso
# true = activado, false = desactivado
XSS_AUDIT=true

# Servidor de callback donde se recibirán los hits de XSS
# Debe ser accesible públicamente desde los sandboxes
CALLBACK_SERVER=http://54.37.226.179
