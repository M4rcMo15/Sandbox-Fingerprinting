# Configuración del agente de detección de sandbox

# URL del servidor donde se enviarán los datos
# Ejemplo desarrollo local:
# SERVER_URL=http://localhost:8080/api/collect
# Ejemplo producción:
SERVER_URL=http://your-server.com/api/collect

# Habilitar modo debug (1 = activado, 0 = desactivado)
DEBUG=0

# Timeout para peticiones HTTP (aumentado para payloads grandes)
TIMEOUT=120s
